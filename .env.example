# LaundryIQ Web Monorepo — Environment Variables
# Copy relevant sections to the appropriate app's .env.local file.
# Never commit .env.local files.

# ─── Convex (all apps) ────────────────────────────────────────────────────────
# dev deployment URL
CONVEX_DEPLOYMENT=dev/leeor-nahum
NEXT_PUBLIC_CONVEX_URL=https://reminiscent-lark-716.convex.cloud
VITE_CONVEX_URL=https://reminiscent-lark-716.convex.cloud

# ─── Clerk (all apps) ─────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → LaundryIQ → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...          # server-only (apps/web, never expose to client)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_... # client-side for portal/dashboard

# ─── Convex package (packages/convex/.env.local) ──────────────────────────────
CLERK_JWT_ISSUER_DOMAIN=https://grown-thrush-53.clerk.accounts.dev

# ─── Device API (api/.env.example for firmware testing) ───────────────────────
# See api/.env.example for device-side credentials
