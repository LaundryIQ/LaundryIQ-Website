# Copy to .env.local for `npx convex dev` / deploy (never commit .env.local).
# CONVEX_DEPLOYMENT: Convex dashboard (e.g. dev:your-slug)
# CLERK_JWT_ISSUER_DOMAIN: Clerk → JWT templates → "convex" template → Issuer

CONVEX_DEPLOYMENT=dev:YOUR_DEPLOYMENT_SLUG
CLERK_JWT_ISSUER_DOMAIN=https://YOUR_INSTANCE.clerk.accounts.dev

CONVEX_URL=https://YOUR_DEPLOYMENT_SLUG.convex.cloud
CONVEX_SITE_URL=https://YOUR_DEPLOYMENT_SLUG.convex.site
