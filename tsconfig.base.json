{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@laundryiq/convex/*": ["packages/convex/*"],
      "@laundryiq/ui": ["packages/ui/src/index.ts"],
      "@laundryiq/utils": ["packages/utils/src/index.ts"]
    }
  }
}
