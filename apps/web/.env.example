# Copy to .env.local (never commit .env.local).
# Match the exact variable order/format used in `.env.local`.
# Marketing points to portal locally on 5173 and dashboard locally on 5174.

NEXT_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_INSTANCE.clerk.accounts.dev$
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY

# Cross-app URLs — localhost for local dev; set production URLs in Vercel
NEXT_PUBLIC_PORTAL_URL=http://localhost:5173
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:5174
NEXT_PUBLIC_SHOP_URL=https://shop.laundryiq.app
